    {
      "name": "news",
      "label": "Newsroom",
      "icon": "file",
      "kind": "single",
      "path": "content/news.json",
      "fields": [
        {
          "name": "items",
          "label": "News & press (drag to reorder)",
          "type": "list",
          "min": 1,
          "of": {
            "type": "object",
            "fields": [
              {
                "name": "title",
                "label": "Title",
                "type": "string",
                "required": true
              },
              {
                "name": "type",
                "label": "Category",
                "type": "select",
                "required": true,
                "options": [
                  "Thought Leadership",
                  "Article",
                  "Blog",
                  "Press Release",
                  "Interview",
                  "Award",
                  "Event"
                ]
              },
              {
                "name": "date",
                "label": "Date",
                "type": "date",
                "required": true
              },
              {
                "name": "summary",
                "label": "Summary",
                "type": "text"
              },
              {
                "name": "hero",
                "label": "Image",
                "type": "image"
              },
              {
                "name": "link",
                "label": "Link (page or external URL)",
                "type": "url",
                "required": true
              },
              {
                "name": "featured",
                "label": "Featured",
                "type": "boolean",
                "default": false
              }
            ]
          }
        }
      ]
    },
    {
      "name": "pages",
      "label": "HTML Pages",
      "icon": "file",
      "kind": "collection",
      "folder": ".",
      "extension": "html",
      "primaryField": "path",
      "include": [
        "index.html",
        "about/index.html",
        "blog/index.html"
      ],
      "fields": [
        {
          "name": "path",
          "label": "File path",
          "type": "string",
          "required": true,
          "ui": {
            "hidden": true
          }
        },
        {
          "name": "body",
          "label": "Page HTML",
          "type": "code",
          "language": "html",
          "required": true
        }
      ]
    },
    {
      "name": "products",
      "label": "Shop / Products",
      "icon": "menu",
      "kind": "collection",
      "folder": "content/products",
      "extension": "json",
      "primaryField": "sku",
      "fields": [
        {
          "name": "sku",
          "label": "SKU / ID (used in the URL)",
          "type": "string",
          "required": true
        },
        {
          "name": "price",
          "label": "Price (e.g. 29.99)",
          "type": "number",
          "required": true,
          "min": 0
        },
        {
          "name": "currency",
          "label": "Currency",
          "type": "select",
          "options": [
            "usd",
            "eur",
            "gbp",
            "cad",
            "aud"
          ],
          "required": true,
          "default": "usd"
        },
        {
          "name": "image",
          "label": "Product image",
          "type": "image"
        },
        {
          "name": "active",
          "label": "For sale",
          "type": "boolean",
          "default": true
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "name",
              "label": "Name",
              "type": "string",
              "required": true
            },
            {
              "name": "description",
              "label": "Description",
              "type": "text"
            }
          ]
        },
        {
          "name": "fa",
          "label": "فارسی (Persian)",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "name",
              "label": "Name",
              "type": "string",
              "required": true
            },
            {
              "name": "description",
              "label": "Description",
              "type": "text"
            }
          ]
        },
        {
          "name": "es",
          "label": "Español",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "name",
              "label": "Name",
              "type": "string",
              "required": true
            },
            {
              "name": "description",
              "label": "Description",
              "type": "text"
            }
          ]
        }
      ]
    },
    {
      "name": "navigation",
      "label": "Navigation Menu",
      "icon": "menu",
      "kind": "single",
      "path": "content/navigation.json",
      "fields": [
        {
          "name": "items",
          "label": "Menu items (drag to reorder)",
          "type": "list",
          "min": 1,
          "of": {
            "type": "object",
            "fields": [
              {
                "name": "label",
                "label": "Label",
                "type": "string",
                "required": true
              },
              {
                "name": "url",
                "label": "Link",
                "type": "url",
                "required": true
              },
              {
                "name": "newTab",
                "label": "Open in new tab",
                "type": "boolean",
                "default": false
              }
            ]
          }
        }
      ]
    }
  ]
}
