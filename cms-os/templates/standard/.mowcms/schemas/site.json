{
  "project": "STANDARD",
  "label": "MOW CMS — Standard Starter",
  "description": "The default content model for every MOW site: multilingual homepage, blog/news, pages, shop/products, navigation, and settings. Copy .mowcms/ + content/ into a new site repo and adjust the languages and fields as needed.",
  "languages": [
    "en",
    "fa",
    "es"
  ],
  "schemas": [
    {
      "name": "home",
      "label": "Homepage",
      "icon": "home",
      "kind": "single",
      "path": "content/home.json",
      "fields": [
        {
          "name": "images",
          "label": "Images",
          "type": "object",
          "fields": [
            {
              "name": "logo",
              "label": "Logo",
              "type": "image"
            },
            {
              "name": "hero",
              "label": "Hero image",
              "type": "image"
            },
            {
              "name": "og_image",
              "label": "Social share image",
              "type": "image"
            }
          ]
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "seo_title",
              "label": "SEO title (browser tab + Google)",
              "type": "string",
              "required": true,
              "maxLength": 70
            },
            {
              "name": "seo_description",
              "label": "SEO description (Google snippet)",
              "type": "text",
              "required": true,
              "maxLength": 320
            },
            {
              "name": "hero_eyebrow",
              "label": "Hero — small label",
              "type": "string"
            },
            {
              "name": "hero_title",
              "label": "Hero — headline",
              "type": "string",
              "required": true
            },
            {
              "name": "hero_subhead",
              "label": "Hero — paragraph",
              "type": "text"
            },
            {
              "name": "cta_primary",
              "label": "Primary button",
              "type": "string"
            },
            {
              "name": "cta_secondary",
              "label": "Secondary button",
              "type": "string"
            }
          ]
        },
        {
          "name": "fa",
          "label": "فارسی (Persian)",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "seo_title",
              "label": "SEO title (browser tab + Google)",
              "type": "string",
              "maxLength": 70
            },
            {
              "name": "seo_description",
              "label": "SEO description (Google snippet)",
              "type": "text",
              "maxLength": 320
            },
            {
              "name": "hero_eyebrow",
              "label": "Hero — small label",
              "type": "string"
            },
            {
              "name": "hero_title",
              "label": "Hero — headline",
              "type": "string"
            },
            {
              "name": "hero_subhead",
              "label": "Hero — paragraph",
              "type": "text"
            },
            {
              "name": "cta_primary",
              "label": "Primary button",
              "type": "string"
            },
            {
              "name": "cta_secondary",
              "label": "Secondary button",
              "type": "string"
            }
          ]
        },
        {
          "name": "es",
          "label": "Español",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "seo_title",
              "label": "SEO title (browser tab + Google)",
              "type": "string",
              "maxLength": 70
            },
            {
              "name": "seo_description",
              "label": "SEO description (Google snippet)",
              "type": "text",
              "maxLength": 320
            },
            {
              "name": "hero_eyebrow",
              "label": "Hero — small label",
              "type": "string"
            },
            {
              "name": "hero_title",
              "label": "Hero — headline",
              "type": "string"
            },
            {
              "name": "hero_subhead",
              "label": "Hero — paragraph",
              "type": "text"
            },
            {
              "name": "cta_primary",
              "label": "Primary button",
              "type": "string"
            },
            {
              "name": "cta_secondary",
              "label": "Secondary button",
              "type": "string"
            }
          ]
        }
      ]
    },
    {
      "name": "news",
      "label": "Blog / News",
      "icon": "file",
      "kind": "collection",
      "folder": "content/news",
      "extension": "json",
      "primaryField": "date",
      "fields": [
        {
          "name": "date",
          "label": "Publish date",
          "type": "date",
          "required": true
        },
        {
          "name": "cover",
          "label": "Cover image",
          "type": "image"
        },
        {
          "name": "featured",
          "label": "Featured",
          "type": "boolean",
          "default": false
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "title",
              "label": "Title",
              "type": "string",
              "required": true
            },
            {
              "name": "excerpt",
              "label": "Excerpt",
              "type": "text"
            },
            {
              "name": "body",
              "label": "Body",
              "type": "richtext",
              "required": true
            }
          ]
        },
        {
          "name": "fa",
          "label": "فارسی (Persian)",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "title",
              "label": "Title",
              "type": "string"
            },
            {
              "name": "excerpt",
              "label": "Excerpt",
              "type": "text"
            },
            {
              "name": "body",
              "label": "Body",
              "type": "richtext"
            }
          ]
        },
        {
          "name": "es",
          "label": "Español",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "title",
              "label": "Title",
              "type": "string"
            },
            {
              "name": "excerpt",
              "label": "Excerpt",
              "type": "text"
            },
            {
              "name": "body",
              "label": "Body",
              "type": "richtext"
            }
          ]
        }
      ]
    },
    {
      "name": "faqs",
      "label": "FAQ",
      "icon": "file",
      "kind": "collection",
      "folder": "content/faqs",
      "extension": "json",
      "primaryField": "id",
      "fields": [
        {
          "name": "id",
          "label": "ID / slug",
          "type": "string",
          "required": true
        },
        {
          "name": "category",
          "label": "Category",
          "type": "string"
        },
        {
          "name": "featured",
          "label": "Featured",
          "type": "boolean",
          "default": false
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "question",
              "label": "Question",
              "type": "string",
              "required": true
            },
            {
              "name": "answer",
              "label": "Answer",
              "type": "richtext",
              "required": true
            }
          ]
        },
        {
          "name": "fa",
          "label": "فارسی (Persian)",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "question",
              "label": "Question",
              "type": "string"
            },
            {
              "name": "answer",
              "label": "Answer",
              "type": "richtext"
            }
          ]
        },
        {
          "name": "es",
          "label": "Español",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "question",
              "label": "Question",
              "type": "string"
            },
            {
              "name": "answer",
              "label": "Answer",
              "type": "richtext"
            }
          ]
        }
      ]
    },
    {
      "name": "pages",
      "label": "Pages",
      "icon": "file",
      "kind": "collection",
      "folder": "content/pages",
      "extension": "json",
      "primaryField": "slug",
      "fields": [
        {
          "name": "slug",
          "label": "URL slug",
          "type": "string",
          "required": true
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "title",
              "label": "Title",
              "type": "string",
              "required": true
            },
            {
              "name": "body",
              "label": "Body",
              "type": "richtext",
              "required": true
            }
          ]
        },
        {
          "name": "fa",
          "label": "فارسی (Persian)",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "title",
              "label": "Title",
              "type": "string"
            },
            {
              "name": "body",
              "label": "Body",
              "type": "richtext"
            }
          ]
        },
        {
          "name": "es",
          "label": "Español",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "title",
              "label": "Title",
              "type": "string"
            },
            {
              "name": "body",
              "label": "Body",
              "type": "richtext"
            }
          ]
        }
      ]
    },
    {
      "name": "products",
      "label": "Shop / Products",
      "icon": "file",
      "kind": "collection",
      "folder": "content/products",
      "extension": "json",
      "primaryField": "sku",
      "fields": [
        {
          "name": "sku",
          "label": "SKU / ID (used in the URL)",
          "type": "string",
          "required": true
        },
        {
          "name": "price",
          "label": "Price (e.g. 29.99)",
          "type": "number",
          "required": true,
          "min": 0
        },
        {
          "name": "currency",
          "label": "Currency",
          "type": "select",
          "options": [
            "usd",
            "eur",
            "gbp",
            "cad",
            "aud"
          ],
          "required": true,
          "default": "usd"
        },
        {
          "name": "image",
          "label": "Product image",
          "type": "image"
        },
        {
          "name": "active",
          "label": "For sale",
          "type": "boolean",
          "default": true
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "name",
              "label": "Name",
              "type": "string",
              "required": true
            },
            {
              "name": "description",
              "label": "Description",
              "type": "text"
            }
          ]
        },
        {
          "name": "fa",
          "label": "فارسی (Persian)",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "name",
              "label": "Name",
              "type": "string"
            },
            {
              "name": "description",
              "label": "Description",
              "type": "text"
            }
          ]
        },
        {
          "name": "es",
          "label": "Español",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "name",
              "label": "Name",
              "type": "string"
            },
            {
              "name": "description",
              "label": "Description",
              "type": "text"
            }
          ]
        }
      ]
    },
    {
      "name": "menu",
      "label": "Menu (Food & Drink)",
      "icon": "menu",
      "kind": "single",
      "path": "content/menu.json",
      "jsonld": {
        "type": "menu",
        "into": "menu/index.html",
        "langs": [
          "en",
          "fa"
        ]
      },
      "fields": [
        {
          "name": "establishmentType",
          "label": "Business type (for rich results)",
          "type": "select",
          "options": [
            "CafeOrCoffeeShop",
            "Restaurant",
            "Bakery",
            "BarOrPub",
            "FastFoodRestaurant",
            "IceCreamShop",
            "Winery",
            "Brewery"
          ],
          "default": "CafeOrCoffeeShop"
        },
        {
          "name": "businessName",
          "label": "Business name",
          "type": "string"
        },
        {
          "name": "url",
          "label": "Website URL",
          "type": "url"
        },
        {
          "name": "currency",
          "label": "Currency",
          "type": "select",
          "options": [
            "usd",
            "eur",
            "gbp",
            "cad",
            "aud"
          ],
          "default": "usd",
          "required": true
        },
        {
          "name": "image",
          "label": "Menu / hero image",
          "type": "image"
        },
        {
          "name": "sections",
          "label": "Menu sections (drag to reorder)",
          "type": "list",
          "min": 1,
          "of": {
            "type": "object",
            "fields": [
              {
                "name": "en",
                "label": "English",
                "type": "object",
                "ui": {
                  "group": "Languages"
                },
                "fields": [
                  {
                    "name": "name",
                    "label": "Section name",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "label": "Section description",
                    "type": "text"
                  }
                ]
              },
              {
                "name": "fa",
                "label": "فارسی (Persian)",
                "type": "object",
                "ui": {
                  "group": "Languages"
                },
                "fields": [
                  {
                    "name": "name",
                    "label": "Section name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "label": "Section description",
                    "type": "text"
                  }
                ]
              },
              {
                "name": "items",
                "label": "Items (drag to reorder)",
                "type": "list",
                "of": {
                  "type": "object",
                  "fields": [
                    {
                      "name": "price",
                      "label": "Price (e.g. 5.50)",
                      "type": "number",
                      "min": 0
                    },
                    {
                      "name": "image",
                      "label": "Photo",
                      "type": "image"
                    },
                    {
                      "name": "dietary",
                      "label": "Dietary tags",
                      "type": "list",
                      "of": {
                        "type": "select",
                        "options": [
                          "vegan",
                          "vegetarian",
                          "gluten-free",
                          "halal",
                          "kosher",
                          "low-calorie",
                          "low-fat",
                          "low-lactose",
                          "low-salt",
                          "diabetic"
                        ]
                      }
                    },
                    {
                      "name": "en",
                      "label": "English",
                      "type": "object",
                      "ui": {
                        "group": "Languages"
                      },
                      "fields": [
                        {
                          "name": "name",
                          "label": "Item name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "label": "Item description",
                          "type": "text"
                        }
                      ]
                    },
                    {
                      "name": "fa",
                      "label": "فارسی (Persian)",
                      "type": "object",
                      "ui": {
                        "group": "Languages"
                      },
                      "fields": [
                        {
                          "name": "name",
                          "label": "Item name",
                          "type": "string"
                        },
                        {
                          "name": "description",
                          "label": "Item description",
                          "type": "text"
                        }
                      ]
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    },
    {
      "name": "navigation",
      "label": "Navigation Menu",
      "icon": "menu",
      "kind": "single",
      "path": "content/navigation.json",
      "fields": [
        {
          "name": "items",
          "label": "Menu items (drag to reorder)",
          "type": "list",
          "min": 1,
          "of": {
            "type": "object",
            "fields": [
              {
                "name": "url",
                "label": "Link",
                "type": "url",
                "required": true
              },
              {
                "name": "newTab",
                "label": "Open in new tab",
                "type": "boolean",
                "default": false
              },
              {
                "name": "label_en",
                "label": "Label (English)",
                "type": "string",
                "required": true
              },
              {
                "name": "label_fa",
                "label": "Label (فارسی (Persian))",
                "type": "string",
                "required": false
              },
              {
                "name": "label_es",
                "label": "Label (Español)",
                "type": "string",
                "required": false
              }
            ]
          }
        }
      ]
    },
    {
      "name": "settings",
      "label": "Site Settings",
      "icon": "menu",
      "kind": "single",
      "path": "content/settings.json",
      "fields": [
        {
          "name": "email",
          "label": "Contact email",
          "type": "email"
        },
        {
          "name": "phone",
          "label": "Phone",
          "type": "string"
        },
        {
          "name": "social",
          "label": "Social links",
          "type": "list",
          "of": {
            "type": "object",
            "fields": [
              {
                "name": "platform",
                "label": "Platform",
                "type": "select",
                "options": [
                  "instagram",
                  "linkedin",
                  "x",
                  "youtube",
                  "tiktok",
                  "facebook"
                ],
                "required": true
              },
              {
                "name": "url",
                "label": "URL",
                "type": "url",
                "required": true
              }
            ]
          }
        },
        {
          "name": "shop_enabled",
          "label": "Enable shop",
          "type": "boolean",
          "default": false
        },
        {
          "name": "shop_currency",
          "label": "Default currency",
          "type": "select",
          "options": [
            "usd",
            "eur",
            "gbp",
            "cad",
            "aud"
          ],
          "default": "usd"
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "footer_tagline",
              "label": "Footer tagline",
              "type": "text"
            }
          ]
        },
        {
          "name": "fa",
          "label": "فارسی (Persian)",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "footer_tagline",
              "label": "Footer tagline",
              "type": "text"
            }
          ]
        },
        {
          "name": "es",
          "label": "Español",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
            {
              "name": "footer_tagline",
              "label": "Footer tagline",
              "type": "text"
            }
          ]
        }
      ]
    }
  ]
}
