# ---- MOW CMS OS backend configuration ----
# Copy to .env and fill in. (server reads process.env; use your platform's
# env settings, or `node --env-file=.env server.js` on Node 20+.)

# Server
PORT=4000
MOW_CORS_ORIGIN=*

# Security — CHANGE THESE in production
MOW_JWT_SECRET=replace-with-a-long-random-string

# First-boot seed admin (only used if no users exist yet)
MOW_ADMIN_EMAIL=admin@mow.media
MOW_ADMIN_PASSWORD=changeme123

# GitHub access. A fine-grained PAT (or classic token) with Contents:read/write
# on the target repo. Used as the default token for projects without their own.
MOW_GITHUB_TOKEN=

# First-boot seed project (the MOW marketing site)
MOW_REPO_OWNER=manoftheworldmedia
MOW_REPO_NAME=mow
MOW_REPO_BRANCH=main
